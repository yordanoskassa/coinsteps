# CoinSteps Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
MONGODB_URL=mongodb://localhost:27017/stepbet
# For production with authentication:
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/stepbet?retryWrites=true&w=majority

# ============================================
# Authentication & Security
# ============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-here-min-32-chars
# Generate with: openssl rand -hex 32

WALLET_ENCRYPTION_KEY=your-32-character-encryption-key-here
# Must be exactly 32 characters for AES-256 encryption

# ============================================
# Solana Blockchain Configuration
# ============================================
# Devnet (testing/development)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Mainnet-beta (production) - Uncomment for production
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Custom RPC (e.g., QuickNode, Alchemy) - Uncomment if needed
# SOLANA_RPC_URL=https://your-custom-rpc.com

# ============================================
# AI Services (ASI:One Agentic)
# ============================================
ASI_ONE_API_KEY=your_asi_one_api_key_here
# Get from: https://asi1.ai

# ============================================
# Email Notifications (AgentMail)
# ============================================
AGENTMAIL_API_KEY=your_agentmail_api_key_here
AGENTMAIL_INBOX_ID=notis@agentmail.to

# ============================================
# Airdrop Configuration
# ============================================
# Mode: "auto" (default), "treasury", or "faucet"
# - auto: tries treasury first, falls back to public faucet
# - treasury: forces treasury only (requires treasury secrets)
# - faucet: forces public faucet only
AIRDROP_MODE=auto

# Treasury Secrets (required for reliable programmatic airdrops)
# Provide ONE of the following:
# AIRDROP_TREASURY_SECRET_B64=base64_encoded_64_byte_secret
# AIRDROP_TREASURY_SECRET_JSON=[64, integers, array, format]

# ============================================
# Optional: Third-party Services
# ============================================
# For production monitoring/error tracking
# SENTRY_DSN=https://your-sentry-dsn

# For logging
# LOG_LEVEL=info  # debug, info, warn, error

# ============================================
# Health Verification Settings
# ============================================
# Minimum steps required for health challenge verification
MIN_STEPS_FOR_VERIFICATION=1000
# Health data verification timeout in hours
HEALTH_VERIFICATION_TIMEOUT_HOURS=24
