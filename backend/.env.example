MONGO_URL=mongodb://localhost:27017
DB_NAME=stepbet

# Solana
# Required: encryption key to store user wallet private keys (Fernet key). Generate once and keep secret.
WALLET_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# RPC endpoint (testnet recommended for development)
SOLANA_RPC_URL=https://api.testnet.solana.com

# Airdrop mode: "auto" (default) tries treasury first then public faucet; "treasury" forces treasury only; "faucet" forces public faucet only
AIRDROP_MODE=auto

# Optional treasury secrets to enable reliable programmatic airdrops (fallback when faucet is down)
# Provide ONE of the following:
# - AIRDROP_TREASURY_SECRET_B64: base64-encoded 64-byte secret key
# - AIRDROP_TREASURY_SECRET_JSON: JSON array (64 integers) as in Solana CLI keypair file
#AIRDROP_TREASURY_SECRET_B64=
#AIRDROP_TREASURY_SECRET_JSON=
