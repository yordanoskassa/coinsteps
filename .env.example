# CoinSteps Frontend (Expo/React Native) Environment Configuration
# Copy this file to .env and fill in your actual values
# For Expo, variables must be prefixed with EXPO_PUBLIC_ to be accessible in the app

# ============================================
# API Configuration
# ============================================
# Backend API URL - Change this to your backend URL
# Local development (iOS Simulator)
EXPO_PUBLIC_API_URL=http://localhost:8000

# Local development (Android Emulator)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Production/Staging (update with your deployed backend URL)
# EXPO_PUBLIC_API_URL=https://your-backend-domain.com

# ngrok for testing on physical devices
# EXPO_PUBLIC_API_URL=https://your-ngrok-url.ngrok-free.app

# ============================================
# Solana Blockchain
# ============================================
# Network: "devnet" for testing, "mainnet-beta" for production
EXPO_PUBLIC_SOLANA_NETWORK=devnet

# RPC URL (optional - uses default if not set)
# EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# ============================================
# Feature Flags
# ============================================
# Enable health challenges feature
EXPO_PUBLIC_ENABLE_HEALTH_CHALLENGES=true

# Enable betting/gambling features
EXPO_PUBLIC_ENABLE_BETTING=true

# Enable social/friends features
EXPO_PUBLIC_ENABLE_SOCIAL=true

# Enable wallet and crypto features
EXPO_PUBLIC_ENABLE_WALLET=true

# ============================================
# Third-party Services
# ============================================
# Sentry for error tracking (production)
# EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# PostHog for analytics (optional)
# EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_key

# ============================================
# App Configuration
# ============================================
# App environment: development, staging, production
EXPO_PUBLIC_APP_ENV=development

# API timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=30000

# Enable debug logging
EXPO_PUBLIC_DEBUG_LOGS=true
